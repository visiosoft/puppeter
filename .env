# DeepSeek AI Configuration
DEEPSEEK_API_KEY=sk-815010b1fbdf4019b60576b9ea34b0d8
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions

# AI and Heuristics Settings
# Set to 'true' to use AI for DOM selection (recommended)
# Set to 'false' to use only heuristics
USE_AI_FIRST=true

# Set to 'true' to allow fallback to heuristics when AI fails
# Set to 'false' to use AI-only mode (will fail if AI doesn't work)
USE_HEURISTICS_FALLBACK=false

# Post Selection Mode
# Set to 'sequential' to use different posts for each group (cycles through posts.txt)
# Set to 'random' to randomly pick posts each time
POST_SELECTION_MODE=sequential
